{
  "manifest_version": 3,
  "name": "SuperIsland Chrome Bridge",
  "version": "0.1.0",
  "description": "Connects Chrome tabs and AI-agent page state to the SuperIsland macOS app.",
  "key": "",
  "icons": {
    "16": "icons/icon16.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  },
  "permissions": [
    "nativeMessaging",
    "scripting",
    "tabs",
    "webNavigation",
    "webRequest",
    "windows"
  ],
  "host_permissions": [
    "https://lovable.dev/*",
    "https://gemini.google.com/*",
    "https://chatgpt.com/*",
    "https://chat.openai.com/*",
    "https://claude.ai/*",
    "https://app.emergent.sh/*",
    "https://emergent.sh/*",
    "https://v0.app/*",
    "https://v0.dev/*",
    "https://grok.com/*",
    "https://chat.mistral.ai/*",
    "https://chat.deepseek.com/*",
    "https://www.perplexity.ai/*",
    "https://perplexity.ai/*",
    "https://bolt.new/*",
    "https://api.lovable.dev/*",
    "https://lovable-api.com/*",
    "https://api.emergent.sh/*",
    "https://auth.emergent.sh/*",
    "https://ap.emergent.sh/*",
    "https://files.emergent.sh/*",
    "https://mcp.emergent.sh/*",
    "https://assets.emergent.sh/*",
    "https://job-connect.api.emergent.sh/*"
  ],
  "background": {
    "service_worker": "background.js",
    "type": "module"
  },
  "content_scripts": [
    {
      "matches": [
        "https://lovable.dev/*",
        "https://gemini.google.com/*",
        "https://chatgpt.com/*",
        "https://chat.openai.com/*",
        "https://claude.ai/*",
        "https://app.emergent.sh/*",
        "https://emergent.sh/*",
        "https://v0.app/*",
        "https://v0.dev/*",
        "https://grok.com/*",
        "https://chat.mistral.ai/*",
        "https://chat.deepseek.com/*",
        "https://www.perplexity.ai/*",
        "https://perplexity.ai/*",
        "https://bolt.new/*"
      ],
      "js": [
        "content.js"
      ],
      "run_at": "document_idle"
    },
    {
      "matches": [
        "https://lovable.dev/*",
        "https://gemini.google.com/*",
        "https://chatgpt.com/*",
        "https://chat.openai.com/*",
        "https://claude.ai/*",
        "https://app.emergent.sh/*",
        "https://emergent.sh/*",
        "https://v0.app/*",
        "https://v0.dev/*",
        "https://grok.com/*",
        "https://chat.mistral.ai/*",
        "https://chat.deepseek.com/*",
        "https://www.perplexity.ai/*",
        "https://perplexity.ai/*",
        "https://bolt.new/*"
      ],
      "js": [
        "visibility-keepalive.js"
      ],
      "run_at": "document_start",
      "world": "MAIN"
    }
  ]
}
